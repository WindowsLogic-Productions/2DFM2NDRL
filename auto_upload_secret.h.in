#pragma once
// AUTO-GENERATED by CMake from $FM2K_LOG_UPLOAD_SECRET at configure
// time. Do not commit; do not edit by hand. To rotate the secret:
//   1. Update FM2K_LOG_UPLOAD_SECRET in /home/fm2k/logs/.env on the VPS.
//   2. systemctl restart fm2k-logs
//   3. Rebuild client with the new env var set.
//   4. Push new launcher build to users.
//
// If the env var was empty at configure time, this file still gets
// generated with an empty string, and auto-upload is effectively
// disabled (the launcher checks for emptiness and skips Process()).

namespace fm2k {
inline constexpr const char* kLogUploadSecret = "@FM2K_LOG_UPLOAD_SECRET@";
inline constexpr const char* kLogUploadUrl    = "@FM2K_LOG_UPLOAD_URL@";
}  // namespace fm2k
